{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/aaef-ai-va/schemas/tool-action-request.schema.json",
  "title": "Tool Action Request",
  "description": "AI-generated request for a diagnostic tool action. This is not authority to execute.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tool_action_request_id": {
      "type": "string",
      "pattern": "^tar-[A-Za-z0-9._-]+$"
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "action_type": {
      "type": "string",
      "const": "tool_execution"
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "enum": [
        "zap",
        "nmap",
        "nuclei",
        "browser"
      ]
    },
    "operation": {
      "type": "string",
      "enum": [
        "passive_scan",
        "authenticated_crawl",
        "safe_port_discovery",
        "service_version_detection",
        "safe_template_scan",
        "safe_login_check"
      ]
    },
    "credential_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "requested_constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rate_limit": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        },
        "destructive_tests": {
          "type": "boolean"
        },
        "external_discovery": {
          "type": "boolean"
        },
        "evidence_required": {
          "type": "boolean"
        },
        "max_duration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "allowed_time_window_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "rate_limit",
        "destructive_tests",
        "external_discovery",
        "evidence_required"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    }
  },
  "required": [
    "tool_action_request_id",
    "requested_by",
    "requested_at",
    "action_type",
    "target_id",
    "scope_id",
    "tool",
    "operation",
    "reason",
    "requested_constraints"
  ]
}
